---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCldVideoUrl } from "astro-cloudinary/helpers";
import logoCff from "../images/event/LOGO_cff.png";
import theDropt from "../images/event/TheDropt.png";
import frame87 from "../images/event/Frame 87 (1).png";

// Event data
const events = [
	{
		id: 1,
		icon: "",
		image: logoCff,
		cardTitle: "EVENT 1: BREAKIT",
		cardSubtitle: "Deconstruct. Stress Test. Redesign.",
		objectiveTitle: "🎯 Objective",
		objective:
			"Participants analyze and rethink real-world tech products, exposing system flaws and proposing grounded fixes — no code required.",
		color: "#a855f7",
		day: "DAY 1"
	},
	{
		id: 2,
		icon: "",
		image: theDropt,
		cardTitle: "🚀 EVENT 2: THE DROP",
		cardSubtitle: "Launch the Future. Even If It's Fake.",
		objectiveTitle: "🎯 Objective",
		objective:
			"Teams invent fictional future-tech products and launch them like real startups — blending storytelling, design, and satire.",
		color: "#d946ef",
		day: "DAY 2"
	},
	{
		id: 3,
		icon: "",
		image: frame87,
		cardTitle: "Event 3 : Bet for Tech 3.0",
		objectiveTitle: "Objective",
		objective:
			"tests participants' coding skills, strategic thinking, and risk-taking ability by combining problem-solving with betting and psychological decision-making in a high-stakes competitive format.",
		color: "#ec4899",
		day: "DAY 3"
	},
];
---

<Layout title="Events - Triverse">
	<!-- Background Video -->
	<div class="video-background">
		<video autoplay muted loop playsinline preload="auto" class="bg-video">
			<source
				src="https://res.cloudinary.com/dtxhjkgdu/video/upload/v1769102015/Event_Background_vpzjlx.mp4"
				type="video/mp4"
			/>
		</video>
		<div class="video-overlay"></div>
	</div>

	<main class="events-container">
		<!-- Hero Section -->
		<section class="hero-section">
			<div class="constellation-bg"></div>
			<div class="hero-content">
				<h1 class="hero-title">
					<span class="title-line">THE</span>
					<span class="title-line">EVENTS</span>
				</h1>
				<p class="hero-tagline">Three Missions. One Universe.</p>
			</div>
		</section>

		<!-- Events Timeline Section -->
		<section class="timeline-section">
			<div class="timeline-track">
				<!-- Animated Path SVG -->
				<svg class="timeline-path" viewBox="0 0 100 2000" preserveAspectRatio="none">
					<defs>
						<linearGradient id="pathGradient" x1="0%" y1="0%" x2="0%" y2="100%">
							<stop offset="0%" style="stop-color:#a855f7;stop-opacity:0.6" />
							<stop offset="50%" style="stop-color:#d946ef;stop-opacity:0.8" />
							<stop offset="100%" style="stop-color:#ec4899;stop-opacity:0.6" />
						</linearGradient>
					</defs>
					<path 
						d="M 50,0 L 50,2000" 
						stroke="url(#pathGradient)" 
						stroke-width="0.5" 
						fill="none"
						stroke-dasharray="8 12"
						class="base-path"
					/>
					<path 
						id="progressPath"
						d="M 50,0 L 50,2000" 
						stroke="url(#pathGradient)" 
						stroke-width="1.5" 
						fill="none"
						class="progress-path"
					/>
				</svg>

				<!-- Events -->
				<div class="events-flow">
					{events.map((event, index) => (
						<div class="event-station" data-index={index + 1}>
							<!-- Day Marker -->
							<div class="day-marker">
								<div class="marker-ring">
									<div class="marker-dot"></div>
								</div>
								<span class="day-label">{event.day}</span>
							</div>

							<!-- Event Content -->
							<div class="event-content">
								<!-- Logo Display (no frame, pure PNG with glow) -->
								<div class="event-logo-container">
									<div class="logo-glow" style={`--event-color: ${event.color}`}></div>
									<Image src={event.image} alt={event.cardTitle} class="event-logo" />
								</div>

								<!-- Event Details -->
								<div class="event-details">
									<h2 class="event-name">{event.cardTitle}</h2>
									{event.cardSubtitle && (
										<p class="event-tagline">{event.cardSubtitle}</p>
									)}
									
									<div class="objective-section">
										<div class="objective-header">
											<span class="objective-icon">{event.objectiveTitle}</span>
										</div>
										<p class="objective-description">{event.objective}</p>
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</Layout>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700&display=swap');

	:root {
		--bg-dark: #0a0e1a;
		--bg-darker: #060810;
		--purple-bright: #b48bff;
		--purple-deep: #a855f7;
		--pink-bright: #ec4899;
		--glass-border: rgba(255, 255, 255, 0.12);
		--timeline-progress: 0%;
	}

	html {
		background-color: var(--bg-dark);
		scroll-behavior: smooth;
	}

	body {
		background-color: transparent;
		color: #ffffff;
		margin: 0;
		font-family: 'Outfit', system-ui, -apple-system, sans-serif;
		overflow-x: hidden;
	}
</style>

<style>
	.events-container {
		position: relative;
		width: 100%;
		background: transparent;
		z-index: 10;
		min-height: 100vh;
	}

	/* ==================== BACKGROUND VIDEO ==================== */
	.video-background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		pointer-events: none;
		z-index: 1;
	}

	.bg-video {
		position: absolute;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		object-fit: cover;
		object-position: center;
		filter: blur(12px);
	}

	.video-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(
			135deg,
			rgba(10, 14, 26, 0.5) 0%,
			rgba(18, 17, 31, 0.6) 100%
		);
		pointer-events: none;
	}

	/* Reduce blur on mobile for better performance */
	@media (max-width: 768px) {
		.bg-video {
			filter: blur(12px);
		}
	}

	/* ==================== HERO SECTION ==================== */
	.hero-section {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 5vw;
		z-index: 2;
	}

	.constellation-bg {
		position: absolute;
		inset: 0;
		background-image: 
			radial-gradient(2px 2px at 20% 30%, rgba(180, 139, 255, 0.4), transparent),
			radial-gradient(2px 2px at 60% 70%, rgba(217, 70, 239, 0.3), transparent),
			radial-gradient(1px 1px at 50% 50%, rgba(236, 72, 153, 0.4), transparent),
			radial-gradient(1px 1px at 80% 10%, rgba(168, 85, 247, 0.3), transparent),
			radial-gradient(2px 2px at 90% 60%, rgba(180, 139, 255, 0.3), transparent),
			radial-gradient(1px 1px at 33% 80%, rgba(217, 70, 239, 0.4), transparent);
		background-size: 200% 200%;
		background-position: 0% 0%;
		animation: constellation-drift 30s ease-in-out infinite;
		opacity: 0.6;
		pointer-events: none;
	}

	@keyframes constellation-drift {
		0%, 100% { background-position: 0% 0%; }
		50% { background-position: 100% 100%; }
	}

	.hero-content {
		position: relative;
		text-align: center;
		z-index: 2;
	}

	.hero-title {
		margin: 0;
		line-height: 0.85;
		display: flex;
		flex-direction: column;
		gap: 0.1em;
	}

	.title-line {
		font-family: 'Orbitron', monospace;
		font-size: clamp(4rem, 16vw, 11rem);
		font-weight: 900;
		letter-spacing: 0.15em;
		background: linear-gradient(180deg, #ffffff 0%, rgba(180, 139, 255, 0.9) 100%);
		background-clip: text;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		text-shadow: 0 0 80px rgba(180, 139, 255, 0.5);
		animation: title-glow 4s ease-in-out infinite;
		opacity: 0;
		transform: translateY(30px);
		animation: title-enter 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	.title-line:nth-child(1) {
		animation-delay: 0.2s;
	}

	.title-line:nth-child(2) {
		animation-delay: 0.4s;
	}

	@keyframes title-enter {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes title-glow {
		0%, 100% { text-shadow: 0 0 80px rgba(180, 139, 255, 0.5); }
		50% { text-shadow: 0 0 120px rgba(180, 139, 255, 0.8); }
	}

	.hero-tagline {
		font-family: 'Outfit', sans-serif;
		font-size: clamp(1rem, 2.5vw, 1.6rem);
		font-weight: 300;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.6);
		margin-top: 2rem;
		opacity: 0;
		animation: fade-in 1s cubic-bezier(0.16, 1, 0.3, 1) 0.8s forwards;
	}

	@keyframes fade-in {
		to { opacity: 1; }
	}

	/* ==================== TIMELINE SECTION ==================== */
	.timeline-section {
		position: relative;
		min-height: 200vh;
		padding: 15vh 5vw 20vh;
		z-index: 2;
	}

	.timeline-track {
		position: relative;
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Animated Path */
	.timeline-path {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		width: 2px;
		height: 100%;
		pointer-events: none;
		z-index: 1;
	}

	.base-path {
		opacity: 0.3;
	}

	.progress-path {
		stroke-dasharray: 2000;
		stroke-dashoffset: 2000;
		filter: drop-shadow(0 0 8px rgba(180, 139, 255, 0.6));
	}

	/* Vertical Progress Bar */
	.timeline-track::before {
		content: '';
		position: absolute;
		left: 50%;
		top: 0;
		transform: translateX(-50%);
		width: 3px;
		height: 100%;
		background: rgba(180, 139, 255, 0.15);
		z-index: 0;
	}

	.timeline-track::after {
		content: '';
		position: absolute;
		left: 50%;
		top: 0;
		transform: translateX(-50%);
		width: 3px;
		height: var(--timeline-progress);
		background: linear-gradient(180deg, #a855f7 0%, #d946ef 50%, #ec4899 100%);
		box-shadow: 0 0 20px rgba(180, 139, 255, 0.6);
		z-index: 1;
		transition: height 0.05s linear;
	}

	/* Events Flow */
	.events-flow {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		gap: 20vh;
		padding: 5vh 0;
	}

	.event-station {
		position: relative;
		display: flex;
		align-items: center;
		gap: 3rem;
		opacity: 0;
		transform: translateY(60px);
		animation: station-reveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	.event-station[data-index="1"] {
		animation-delay: 0.3s;
		justify-content: flex-end;
	}

	.event-station[data-index="1"] .event-content {
		flex-direction: row-reverse;
		text-align: right;
	}

	.event-station[data-index="2"] {
		animation-delay: 0.6s;
		justify-content: flex-start;
	}

	.event-station[data-index="2"] .event-content {
		text-align: left;
	}

	.event-station[data-index="3"] {
		animation-delay: 0.9s;
		justify-content: flex-end;
	}

	.event-station[data-index="3"] .event-content {
		flex-direction: row-reverse;
		text-align: right;
	}

	@keyframes station-reveal {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Day Marker (on timeline) */
	.day-marker {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.8rem;
		z-index: 3;
	}

	.marker-ring {
		width: 60px;
		height: 60px;
		border: 2px solid rgba(180, 139, 255, 0.4);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(10, 14, 26, 0.9);
		backdrop-filter: blur(10px);
		position: relative;
		animation: ring-pulse 3s ease-in-out infinite;
	}

	@keyframes ring-pulse {
		0%, 100% {
			box-shadow: 0 0 0 0 rgba(180, 139, 255, 0.5);
		}
		50% {
			box-shadow: 0 0 0 10px rgba(180, 139, 255, 0);
		}
	}

	.marker-dot {
		width: 12px;
		height: 12px;
		background: linear-gradient(135deg, #a855f7, #d946ef);
		border-radius: 50%;
		box-shadow: 0 0 20px rgba(180, 139, 255, 0.8);
	}

	.day-label {
		font-family: 'Orbitron', monospace;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		color: var(--purple-bright);
		text-transform: uppercase;
		background: rgba(10, 14, 26, 0.8);
		padding: 0.4rem 1rem;
		border-radius: 20px;
		border: 1px solid rgba(180, 139, 255, 0.3);
	}

	/* Event Content */
	.event-content {
		display: flex;
		align-items: center;
		gap: 3rem;
		max-width: 50%;
	}

	/* Logo Container - NO FRAMES, pure PNG with glow */
	.event-logo-container {
		position: relative;
		flex-shrink: 0;
		width: clamp(180px, 20vw, 280px);
		height: clamp(180px, 20vw, 280px);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.logo-glow {
		position: absolute;
		inset: -30%;
		background: radial-gradient(circle, var(--event-color) 0%, transparent 70%);
		opacity: 0.4;
		animation: logo-glow-pulse 4s ease-in-out infinite;
		pointer-events: none;
		filter: blur(40px);
	}

	@keyframes logo-glow-pulse {
		0%, 100% {
			opacity: 0.3;
			transform: scale(1);
		}
		50% {
			opacity: 0.6;
			transform: scale(1.1);
		}
	}

	.event-logo {
		position: relative;
		width: 100%;
		height: 100%;
		object-fit: contain;
		filter: drop-shadow(0 10px 40px rgba(0, 0, 0, 0.5));
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
		z-index: 2;
	}

	.event-station:hover .event-logo {
		transform: scale(1.05) translateY(-10px);
	}

	/* Event Details */
	.event-details {
		flex: 1;
		min-width: 0;
	}

	.event-name {
		font-family: 'Orbitron', monospace;
		font-size: clamp(1.8rem, 3vw, 2.8rem);
		font-weight: 900;
		margin: 0 0 0.8rem 0;
		letter-spacing: 0.02em;
		line-height: 1.1;
		background: linear-gradient(135deg, #ffffff 0%, rgba(180, 139, 255, 0.9) 100%);
		background-clip: text;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.event-tagline {
		font-size: clamp(1rem, 1.8vw, 1.3rem);
		font-weight: 500;
		color: rgba(255, 255, 255, 0.7);
		margin: 0 0 2rem 0;
		line-height: 1.5;
	}

	.objective-section {
		background: rgba(10, 14, 26, 0.6);
		backdrop-filter: blur(20px);
		border: 1px solid rgba(180, 139, 255, 0.15);
		padding: 1.8rem 2rem;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		text-align: left;
	}

	.event-station[data-index="1"] .objective-section,
	.event-station[data-index="3"] .objective-section {
		text-align: left;
	}

	.event-station[data-index="2"] .objective-section {
		text-align: left;
	}

	.event-station:hover .objective-section {
		border-color: rgba(180, 139, 255, 0.4);
		background: rgba(10, 14, 26, 0.8);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
	}

	.objective-header {
		margin-bottom: 1rem;
	}

	.objective-icon {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--purple-bright);
		letter-spacing: 0.05em;
	}

	.objective-description {
		font-size: clamp(0.95rem, 1.5vw, 1.1rem);
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.8);
		margin: 0;
	}

	/* ==================== RESPONSIVE ==================== */
	@media (max-width: 900px) {
		.timeline-section {
			padding: 10vh 5vw 15vh;
		}

		.events-flow {
			gap: 15vh;
		}

		.event-station[data-index="1"],
		.event-station[data-index="2"],
		.event-station[data-index="3"] {
			justify-content: center;
			flex-direction: column !important;
		}

		.event-content {
			max-width: 100%;
			flex-direction: column !important;
			align-items: center;
			text-align: center;
		}

		.day-marker {
			position: relative;
			left: auto;
			transform: none;
			order: -1;
		}

		.timeline-path {
			display: none;
		}

		.event-logo-container {
			width: clamp(200px, 50vw, 260px);
			height: clamp(200px, 50vw, 260px);
		}

		.objective-section {
			text-align: left;
		}
	}

	@media (max-width: 640px) {
		.events-flow {
			gap: 12vh;
		}

		.event-content {
			gap: 2rem;
		}

		.event-logo-container {
			width: clamp(160px, 45vw, 220px);
			height: clamp(160px, 45vw, 220px);
		}

		.objective-section {
			padding: 1.5rem;
		}

		.marker-ring {
			width: 50px;
			height: 50px;
		}

		.marker-dot {
			width: 10px;
			height: 10px;
		}
	}
</style>

<script>
	// Scroll-triggered timeline progress bar
	const timelineSection = document.querySelector('.timeline-section');
	const timelineTrack = document.querySelector('.timeline-track');

	window.addEventListener('scroll', () => {
		if (!timelineSection || !timelineTrack) return;

		const rect = timelineSection.getBoundingClientRect();
		const sectionTop = rect.top;
		const sectionHeight = rect.height;
		const windowHeight = window.innerHeight;

		// Calculate progress through the timeline section
		const scrollProgress = Math.max(0, Math.min(1, 
			(windowHeight - sectionTop) / (sectionHeight + windowHeight)
		));

		// Update progress bar height
		timelineTrack.style.setProperty('--progress', `${scrollProgress * 100}%`);
		
		// Apply the height to the ::after pseudo-element via CSS variable
		document.documentElement.style.setProperty('--timeline-progress', `${scrollProgress * 100}%`);
	});

	// Parallax effect for constellation background
	let ticking = false;
	window.addEventListener('scroll', () => {
		if (!ticking) {
			window.requestAnimationFrame(() => {
				const scrolled = window.scrollY;
				const constellation = document.querySelector('.constellation-bg');
				if (constellation) {
					constellation.style.transform = `translateY(${scrolled * 0.3}px)`;
				}
				ticking = false;
			});
			ticking = true;
		}
	});
</script>