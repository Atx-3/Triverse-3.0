---
import { Image } from 'astro:assets';
import teamData from '../data/team-details.json';

interface Props {
  teamName: string;
}

const { teamName } = Astro.props;

const team = teamData.teams.find(
  t => t.name.toLowerCase() === teamName.toLowerCase()
);

if (!team) {
  console.error(`Team "${teamName}" not found`);
}

// 🔥 exception handling (ONLY addition)
const hasCoLead = Boolean(team?.colead);

// Load all team images eagerly
const teamImages = import.meta.glob<{ default: ImageMetadata }>('/src/images/team/**/*.{png,jpg,jpeg,webp}', { eager: true });

function resolveImage(path: string | undefined | null) {
  if (!path) return null;
  // Normalize path: replace backslashes with forward slashes
  const normalizedPath = path.replace(/\\/g, '/');
  // Ensure it starts with /team
  const cleanPath = normalizedPath.startsWith('/') ? normalizedPath : '/' + normalizedPath;
  // Construct full path
  const fullPath = `/src/images${cleanPath}`;
  
  const imageModule = teamImages[fullPath];
  return imageModule ? imageModule.default : null;
}

const leadImage = resolveImage(team?.lead?.image);
const coleadImage = hasCoLead ? resolveImage(team?.colead?.image) : null;
---
{team && (
  <section class="team-section">

    <!-- ALL MEMBERS IN GRID -->
    <div class="members-grid">
      <!-- LEAD -->
      <div class="member-card">
        <div class="avatar-wrap member-avatar">
          {leadImage ? (
            <Image src={leadImage} alt={team.lead.name} class="team-img" />
          ) : (
            <div class="placeholder-img"></div>
          )}
          <div class="info">
            <h3>{team.lead.name}</h3>
            <p>{team.lead.role}</p>
          </div>
        </div>
      </div>

      <!-- CO-LEAD -->
      {hasCoLead && (
        <div class="member-card">
          <div class="avatar-wrap member-avatar">
            {coleadImage ? (
              <Image src={coleadImage} alt={team.colead?.name ?? ''} class="team-img" />
            ) : (
              <div class="placeholder-img"></div>
            )}
            <div class="info">
              <h3>{team.colead?.name}</h3>
              <p>{team.colead?.role}</p>
            </div>
          </div>
        </div>
      )}

      <!-- MEMBERS -->
      {team.members.map(member => {
        const memberImage = resolveImage(member.image);
        return (
          <div class="member-card">
            <div class="avatar-wrap member-avatar">
              {memberImage ? (
                <Image src={memberImage} alt={member.name} class="team-img" />
              ) : (
                <div class="placeholder-img"></div>
              )}
              <div class="info">
                <h4>{member.name}</h4>
                <p>{member.role}</p>
              </div>
            </div>
          </div>
        )
      })}
    </div>

  </section>
)}

<style>
/* ---------- SECTION ---------- */
.team-section {
  max-width: 1100px;
  margin: 0rem auto 0;
  padding: 0 1rem;
}

/* ---------- AVATAR WITH GALAXY BACKGROUND ---------- */
.avatar-wrap {
  position: relative;
  width: 240px;
  height: 320px;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(15, 5, 20, 0.3) 0%, rgba(30, 15, 45, 0.5) 30%, rgba(60, 20, 100, 0.85) 60%, rgba(100, 40, 160, 0.9) 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  border-radius: 8px;
  box-shadow: 0 4px 16px rgba(100, 50, 200, 0.1);
}

.avatar-wrap .info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20px 15px 15px;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.5) 50%, rgba(0, 0, 0, 0.85) 100%);
  z-index: 2;
  text-align: center;
}

.avatar-wrap .info h3,
.avatar-wrap .info h4 {
  margin: 0 0 5px 0;
  font-size: 1.1rem;
  font-weight: 600;
  color: #fff;
}

.avatar-wrap .info p {
  margin: 0;
  font-size: 0.9rem;
  color: #ddd;
}

/* ---------- SIMPLE IMAGE ---------- */
.team-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
  background: transparent;
  transform: none;
  transition: transform 0.3s ease;
  border-radius: 6px;
}

.avatar-wrap:hover .team-img {
  transform: scale(1.02);
}

/* ---------- MEMBERS GRID ---------- */
.members-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.2rem;
  margin-top: 0.5rem;
  justify-items: center;
}

/* ---------- MEMBER CARD ---------- */
.member-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: transform 0.3s ease;
}

.member-card:hover {
  transform: translateY(-10px);
}

.member-avatar {
  margin-bottom: 0.45rem;
}

/* ---------- RESPONSIVE ---------- */
@media (max-width: 941px) {
  .members-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .avatar-wrap {
    width: 150px;
    height: 150px;
  }
}
</style>
